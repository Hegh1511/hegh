@article{he2025aetmc,
  title = {{AETMC-FCVT}: An End-to-End Welding Defect Detection and Classification Method Based on Magneto-Optical Infrared Bi-Imaging System},
  author = {Guohua He and Xiangdong Gao* and Haojun Yang},
  year = {2025},
  month = feb,
  journal = {Mechanical Systems and Signal Processing},
  casquartile = {中科院1区},
  jcrquartile = {JCR Q1},
  volume = {224},
  pages = {112058},
  issn = {0888-3270},
  doi = {10.1016/j.ymssp.2024.112058},
  urldate = {2026-06-29},
  langid = {english},
  abstract = {The reliability and safety of welded structures is contingent upon the ability to accurately identify and rectify welding defects. However, current detection technologies face challenges in precision, efficiency, and accuracy, highlighting the need for further enhancements to improve productivity and reliability. To improve the accuracy and reliability of welding defect detection, this study proposes an innovative magneto-optical infrared bi-imaging method. Meanwhile, a multimodal fusion classification model, i.e., the end-to-end attention-enhanced trusted multi-modal classification model based on fusion convolutional neural network and vision transformer transfer learning, is proposed in this study. The image data of resistance spot welded joints, including defect-free, incompletely fusion, pit, and crack, were obtained using a magneto-optical infrared bi-imaging system. The results indicate that the inspection system demonstrates high precision and efficiency in defect recognition. The trained AETMC-FCVT model effectively and robustly identifies four typical welding states of resistance welding joints. The evaluation metrics for the four-class classification model exceed 96 percent, while those for the two-class classification model surpass 99 percent. Furthermore, results from ablation and comparative experiments demonstrate that the AETMC-FCVT model significantly enhances performance. The methodology proposed in this study represents a novel advancement in welding quality inspection techniques.},
  description = {An end-to-end trusted multimodal fusion model for detecting and classifying resistance-spot-welding defects from magneto-optical and infrared images.},
  keywords = {Welding Defect Detection, Magneto-Optical Imaging, Infrared Thermography, Multimodal Fusion, AETMC-FCVT}
}


@article{he2026hybrid,
  title = {Hybrid Data and Mechanism Driven {3D} Reconstruction System of Welding Defects Using Magneto Optical Imaging under a Controllable Rotating Magnetic Field},
  author = {Guohua He and Xiangdong Gao* and Yanxi Zhang},
  year = {2026},
  month = jun,
  journal = {Optics \& Laser Technology},
  casquartile = {中科院2区},
  jcrquartile = {JCR Q1},
  volume = {198},
  pages = {114926},
  issn = {0030-3992},
  doi = {10.1016/j.optlastec.2026.114926},
  urldate = {2026-06-29},
  langid = {english},
  abstract = {The accurate detection of welding defects is imperative for ensuring the structural integrity and safety of welded components. To enhance the performance of magneto optical imaging in the inspection of welding defects, a 3D reconstruction system that is data and mechanism driven operating under a rotating magnetic field that can be controlled is proposed. In this system, a controllable rotating magnetic field magneto optical imaging system acquires multi angle image sequences of welding defects, and a 3D block matching algorithm performs denoising. Utilising these data, a parallel feature extraction framework integrates a mechanism based temporal stream with a saliency based spatial stream. Subsequently, pixel level adaptive weighted fusion generates defect feature maps. The physical characteristics of magneto optical sensing, adaptive threshold segmentation and morphological analysis are exploited in order to achieve precise reconstruction of two dimensional defect contours. The 2D contours are then utilised to reconstruct the 3D depth profiles of the defects through the implementation of a multi angle magneto optical gradient deviation algorithm. The experimental results indicate that the relative deviations of the reconstructed 2D contours and 3D depths both remain below 1 percent. Furthermore, the findings of the ablation studies and tests on real welding specimens confirm the method's ability to accurately recover 3D defect morphology. The proposed approach thus provides a high precision, fully automated 3D visual solution for non destructive detection and evaluation of welding defects, delivering significant engineering value.},
  description = {A hybrid data- and mechanism-driven system for high-precision three-dimensional reconstruction of welding defects from multi-angle magneto-optical images.},
  keywords = {Magneto Optical Imaging, Welding Defects, Controlled Rotating Magnetic Field, Data and Mechanism Driven, 3D Reconstruction}
}

@article{he2026magneto,
  title = {Magneto Optical Imaging Non-Destructive Testing of Welding Defects with Controlled Rotationally Excited Magnetic Field Based on Improved {NSCT-GWO-PCNN} Image Fusion},
  author = {Guohua He and Xiangdong Gao* and Yanxi Zhang},
  year = {2026},
  month = jun,
  journal = {Optics and Lasers in Engineering},
  casquartile = {中科院2区},
  jcrquartile = {JCR Q1},
  volume = {201},
  pages = {109718},
  issn = {0143-8166},
  doi = {10.1016/j.optlaseng.2026.109718},
  urldate = {2026-06-29},
  langid = {english},
  abstract = {Within the industrial manufacturing sector, the identification of welding defects is paramount to ensuring product quality and operational safety. Magneto optical imaging systems of the conventional kind are limited by fixed excitation parameters, which renders them ill-equipped to comprehensively capture the multidimensional morphology of complex defects. This study builds upon existing unidirectional rotating magnetic field excitation techniques, integrating an adaptive pulse-coupled neural network image processing method based on grey wolf optimization and non-subsampled contourlet transform. This approach establishes a controllable rotating excitation magnetic field magneto optical imaging experimental system for welded specimens, proposing a strategy to determine excitation magnetic field current-frequency parameters based on material electromagnetic properties. This procedure enables stable acquisition of multi-angle leakage-field response sequences across excitation settings. The efficacy of the method was demonstrated through a combination of finite element simulations and experimental validation on 65Mn and Q235 welded specimens. Results are cross-checked against optical images and portable X-ray inspections. The results of these comparisons demonstrated the method's ability to continuously and clearly reconstruct defects such as cracks, pits, and lack of fusion. A comparison of the multi-angle raw sequence averaging method and conventional baseline methods reveals that the final enhanced images exhibit improvements in metrics including information entropy, mean gradient, and standard deviation. This improves contour integrity and visual contrast under strong magnetic-domain background interference. The method provides a portable solution for rapid, radiation-free, and highly interpretable non-destructive testing of weld defects.},
  description = {A controllable rotating-field magneto-optical inspection method that fuses multi-angle images using an improved NSCT-GWO-PCNN algorithm.},
  keywords = {Image Fusion, Magneto Optical Imaging, Non-Destructive Testing, Rotating Magnetic Fields, Welding Defects}
}

@article{du2025lowcarbon,
  title = {面向低碳的零部件表面涂层方案综合评价方法},
  author = {杜彦斌 and 何国华 and 曾丹 and 马文生},
  year = {2025},
  month = mar,
  journal = {计算机集成制造系统},
  volume = {31},
  number = {3},
  pages = {804--814},
  issn = {1006-5911},
  doi = {10.13196/j.cims.2022.0764},
  urldate = {2026-06-29},
  langid = {chinese},
  abstract = {针对目前零部件表面涂层方案选择主要考虑技术性、经济性的问题，提出一种面向低碳的零部件表面涂层方案综合评价方法。融入绿色低碳指标，构建涵盖技术可行性、经济性、绿色低碳、改性性能等因素的零部件表面涂层方案综合评价指标体系，并确定各个指标的量化方法；针对单一赋权法具有一定偏向性的问题，利用网络层次分析法和CRITIC法分别确定准则层各指标的主观权重与客观权重，并利用最小相对信息熵获得主客观组合权重；采用灰色关联改进的多准则妥协解排序法对表面改性方案进行综合评价，通过优劣解排序确定最佳表面涂层方案。以某水泵厂柱塞零部件的表面硬化为例，验证所提出方法的可行性和有效性，为各类零部件表面涂层方案评价及选择提供参考。},
  description = {构建融合绿色低碳指标、组合赋权与灰色关联VIKOR的零部件表面涂层方案综合评价方法。},
  keywords = {低碳, 表面涂层, 组合权重, 综合评价}
}

@article{he2024oct,
  title = {{OCT} Monitoring Data Processing Method of Laser Deep Penetration Welding Based on {HDBSCAN}},
  author = {Guohua He and Xiangdong Gao* and Laiming Li and Pengyu Gao},
  year = {2024},
  month = dec,
  journal = {Optics \& Laser Technology},
  casquartile = {中科院2区},
  jcrquartile = {JCR Q1},
  volume = {179},
  pages = {111303},
  issn = {0030-3992},
  doi = {10.1016/j.optlastec.2024.111303},
  urldate = {2026-06-29},
  langid = {english},
  abstract = {To address the challenge of low accuracy in the measurement of laser deep penetration welding depth, this study introduces optical coherence tomography technology for the direct measurement of this parameter, which is designed to enable real-time measurement and the accurate acquisition of depth information. This study has developed a laser welding depth inspection system that integrates spectral-domain OCT, utilizing 304 stainless steel as the test material for inspecting laser deep penetration welding. A comparative analysis evaluated the impact of HDBSCAN, DBSCAN, and K-means clustering on the clustering of OCT raw data, in addition to the use of percentile filters combined with the exponential moving average method for extracting the depth-of-melt curve. The depth-of-melt curve obtained via the HDBSCAN algorithm more accurately reflects the actual depth curve, with an average error remaining below 5 percent. This error rate is 46 percent lower than that of DBSCAN and 42 percent lower than that of K-means. The results of experiments with continuously varying process parameters show that a high degree of accuracy can be demonstrated even when the welding process parameters are continuously varied. Experimental results indicate that the combination of the HDBSCAN algorithm with percentile filtering and the exponential moving average method significantly enhances the recognition accuracy of the deep penetration laser welding depth curve. This method provides more precise feature parameters for the real-time detection and identification of defects in deep penetration laser welding, thereby offering strong support for optimizing and controlling the laser welding process.},
  description = {A real-time OCT depth-signal processing method combining HDBSCAN clustering, percentile filtering, and exponential moving averaging.},
  keywords = {Laser Welding, OCT, Monitoring, Depth of Penetration, HDBSCAN}
}

@article{du2024heat,
  title = {Effect of Heat Treatment on Microstructure and Mechanical Properties of {Fe60} Coating by Laser Cladding on 304 Stainless Steel},
  author = {Yanbin Du* and Yunchuan Peng and Qiang Liang and Zhiqiang Li and Jian Tu},
  year = {2024},
  month = mar,
  journal = {Journal of Materials Research and Technology},
  casquartile = {中科院2区},
  jcrquartile = {JCR Q1},
  volume = {29},
  pages = {2825--2834},
  issn = {2238-7854},
  doi = {10.1016/j.jmrt.2024.02.046},
  urldate = {2026-06-29},
  langid = {english},
  abstract = {Heat treatment has a direct effect on the microstructure and mechanical properties of laser cladding coatings. To investigate the influence of heat treatment on the microstructure and mechanical properties of Fe60 coating, the surface of 304 stainless steel was coated with Fe60 coating by laser cladding technology, and then normalizing treatments were conducted on the coatings at temperatures of 950 degrees Celsius, 1000 degrees Celsius, and 1050 degrees Celsius, as well as a solution treatment at 1050 degrees Celsius. The microstructure and phase composition of the coatings before and after heat treatment were analyzed using optical microscopy, scanning electron microscopy, and X-ray diffractometry. In addition, the microhardness, tensile properties, and impact toughness of the coating were evaluated through experimental testing. The results show that no phase transition occurs in the coatings after heat treatment. Subsequent to normalizing treatments, the grains are gradually refined with the increase of normalizing temperature. Solution treatment leads to grain refinement in the coating and significantly eliminates precipitated phases. Heat treatment effectively reduces residual stress and lattice distortion in the coating, which reduces the microhardness and significantly improves tensile properties and impact resistance at the same time. Observation of the tensile fracture microstructure reveals ductile dimple fractures in the substrate and brittle cleavage fractures within the coated region. The results can provide a valuable reference for enhancing the mechanical properties of Fe60 coatings by laser cladding.},
  description = {An experimental study of how normalizing and solution treatments alter the microstructure and mechanical behavior of laser-cladded Fe60 coatings.},
  keywords = {Laser Cladding, Fe60, Heat Treatment, Mechanical Properties}
}

@article{du2024energy,
  title = {Effect of Laser Specific Energy on Mechanical Properties of {Fe60} Coatings by Laser Cladding},
  author = {Yanbin Du* and Yunchuan Peng and Kaiyi Mao and Guohua He and Lei Zhang},
  year = {2024},
  month = may,
  journal = {Optics \& Laser Technology},
  casquartile = {中科院2区},
  jcrquartile = {JCR Q1},
  volume = {172},
  pages = {110497},
  issn = {0030-3992},
  doi = {10.1016/j.optlastec.2023.110497},
  urldate = {2026-06-29},
  langid = {english},
  abstract = {To reveal the effect of laser specific energy on the mechanical properties of Fe60 coatings, and determine the laser specific energy as well as the corresponding process parameters for the optimal mechanical properties of the coatings, Fe60 coatings were prepared on the surface of 304 stainless steels by laser cladding. The microhardness, tensile properties, and impact properties of the coatings were investigated at different laser specific energies by changing the laser power and scanning speed. The results show that the Fe60 coatings are mainly composed of cryptocrystalline martensite, carbides, a small amount of ferrite and residual austenite. Compared with the substrate, the microhardness of Fe60 coatings is significantly increased, the tensile properties of Fe60 coatings are reduced, brittle cleavage fracture characteristics are presented, and the impact toughness of Fe60 coatings is slightly reduced. With the increase of laser specific energies, the microhardness, tensile properties, and impact properties of the coatings show a trend of increasing and then decreasing. When the laser power is 2300 W, the scanning speed is 11 mm/s, and the laser specific energy is 105 J/mm2, the coatings with the optimal mechanical properties can be obtained. The results can provide a reference for preparing Fe60 coating of excellent performance by adjusting the laser specific energy through synthetically coordinating the laser cladding process parameters.},
  description = {An analysis linking laser specific energy to the microhardness, tensile behavior, and impact toughness of Fe60 laser-cladded coatings.},
  keywords = {Laser Cladding, Laser Specific Energy, Fe60, Mechanical Properties}
}

@article{he2023modeling,
  title = {Modeling and Optimization Method of Laser Cladding Based on {GA-ACO-RFR} and {GNSGA-II}},
  author = {Guohua He and Yanbin Du* and Qiang Liang and Zhijie Zhou and Linsen Shu},
  year = {2023},
  month = sep,
  journal = {International Journal of Precision Engineering and Manufacturing-Green Technology},
  casquartile = {中科院3区},
  jcrquartile = {JCR Q1},
  volume = {10},
  number = {5},
  pages = {1207--1222},
  issn = {2288-6206},
  doi = {10.1007/s40684-022-00492-2},
  urldate = {2026-06-29},
  langid = {english},
  abstract = {Laser cladding is an environmentally friendly and reliable surface modification technology. The quality characteristics of the coating are directly affected by the process parameters of laser cladding. The reasonable selection of process parameters is essential to obtain high-quality coating. In this study, the single-track 15-5PH alloy coating was fabricated on the surface of 12Cr13 stainless steel. In view of the hybrid Genetic Algorithm and Ant Colony Optimization can effectively improve the prediction ability and robustness of Random Forest Regression, a prediction method of cladding layer quality characteristics based on GA-ACO-RFR was proposed. The fast non-dominated ranking genetic algorithm with elite strategy by introducing the Gaussian distribution crossover operator was used to optimize the process parameters of laser cladding. The results showed that the multi-objective optimization method of laser cladding process parameters proposed in this paper can obtain high-quality laser cladding coating. This work demonstrated the potential of the proposed method in laser cladding process prediction and optimization.},
  description = {A machine-learning prediction and evolutionary multi-objective optimization framework for selecting laser-cladding process parameters.},
  keywords = {Laser Cladding, Coating, GA-ACO-RFR, GNSGA-II, Modeling and Optimization}
}

@article{du2023multiobjective,
  title = {Multi-Objective Optimization of Process Parameters of Laser Cladding {15-5PH} Alloy Powder Based on Gray-Fuzzy {Taguchi} Approach},
  author = {Yanbin Du* and Guohua He and Zhijie Zhou and Lei Xu and Meina Huang},
  year = {2023},
  month = apr,
  journal = {Engineering Research Express},
  casquartile = {中科院4区},
  jcrquartile = {JCR Q2},
  volume = {5},
  number = {2},
  pages = {025015},
  issn = {2631-8695},
  doi = {10.1088/2631-8695/acc9fe},
  urldate = {2026-06-29},
  langid = {english},
  abstract = {Laser cladding is a new surface treatment technology that is widely used for surface modification of metal parts, and the high quality of the surface geometry of the cladding layer can save a lot of resources for the company. To obtain high quality of the clad layer, the L25 Taguchi experiment of laser cladding process parameters was designed to laser-clad a single 15-5PH layer on the surface of 45 steel; the effect of process parameters on the surface morphology and dilution rate of the coating was determined by analysis of variance; the optimal combination of process parameters was obtained by combining gray correlation and fuzzy inference system method. The analysis of variance results show that the scanning speed among the laser cladding process parameters plays a key role in obtaining the best superposition of the four geometrical features of the cladding layer simultaneously. With the optimization objectives of larger clad width and height, smaller clad depth, and 30 percent dilution rate, the optimal combination of process parameters obtained based on the gray-fuzzy Taguchi approach was compared and analyzed to find a significant improvement in the geometric quality characteristics of the optimized clad layer. Analysis of microstructure, physical phase, hardness, wear resistance and corrosion resistance showed that the 15-5PH clad layer was able to effectively enhance the surface properties of the 12Cr13 substrate. The optimization method proposed in this study can solve the problem of parameter optimization in industrial multi-parameter and multi-response processes.},
  description = {A gray-fuzzy Taguchi method for jointly optimizing multiple geometric and performance responses in 15-5PH laser cladding.},
  keywords = {Laser Cladding, Taguchi Method, Grey Relational Analysis, Fuzzy Inference System, Parameter Optimization}
}

@article{li2023overlap,
  title = {Optimization of the Overlap Rate of Multi-Track Laser Cladding Based on the Flat-Top Overlapping Model},
  author = {Zhiqiang Li and Yanbin Du* and Guohua He and Zhijie Zhou and Qiang Liang and Linsen Shu},
  year = {2023},
  month = oct,
  journal = {Transactions of the Indian Institute of Metals},
  casquartile = {中科院4区},
  jcrquartile = {JCR Q3},
  volume = {76},
  number = {10},
  pages = {2773--2782},
  issn = {0972-2815},
  doi = {10.1007/s12666-023-02972-8},
  urldate = {2026-06-29},
  langid = {english},
  abstract = {The overlap rate of multi-track laser cladding determines the surface flatness of the cladding layer. To improve the surface flatness of the cladding layer, an optimization method for the overlap rate of multi-track laser cladding layer based on the flat-top overlapping model is proposed. Firstly, the cross-section profile data of single-track laser cladding are collected, and curve fitting is performed to obtain the optimal fitting cross-section function. Then, the multi-track overlapping model is established based on the optimal fitting function, and the optimal overlap rate model for the multi-track laser cladding is derived theoretically. Finally, the optimization method of the overlap rate is verified experimentally, using 20Cr13 as the substrate and M2, 316L and 15-5PH as the coating powders. The experimental results showed that the flatness of the multi-track cladding layers with different cladding powders is greater than 85 percent with minor errors. It is shown that the model is helpful to obtain good surface flatness and is suitable for various powders, and the model has good effectiveness and versatility.},
  description = {A material-general flat-top overlap model for selecting the multi-track laser-cladding overlap rate and improving surface flatness.},
  keywords = {Additive Manufacturing, Laser Cladding, Overlapping Model, Curve Fitting}
}

@article{zhou2023optimization,
  title = {Optimization and Characterization of Laser Cladding of {15-5PH} Coating on {20Cr13} Stainless Steel},
  author = {Zhijie Zhou and Yanbin Du* and Guohua He and Lei Xu and Linsen Shu},
  year = {2023},
  month = feb,
  journal = {Journal of Materials Engineering and Performance},
  casquartile = {中科院4区},
  jcrquartile = {JCR Q3},
  volume = {32},
  number = {3},
  pages = {962--977},
  issn = {1059-9495},
  doi = {10.1007/s11665-022-07157-w},
  urldate = {2026-06-29},
  langid = {english},
  abstract = {Laser cladding is considered to be an attractive technology that offers tremendous advantages in rapidly surface repair of damaged components. Single-track cladding layer is the basic unit of laser cladding surface repair. Its reasonable geometric quality characteristics can reduce the defects in laser cladding process. In this study, single-track 15-5PH alloy cladding layer was deposited on the surface of 20Cr13 stainless steel substrate by laser cladding technology. In view of the better prediction accuracy and generalization ability of back propagation neural network optimized by grey wolf optimization, a method for predicting the geometrical quality characteristics of cladding layer based on GWO-BPNN was developed, and genetic algorithm was used to optimize process parameters, which significantly improved the geometric quality of single-track 15-5PH cladding layer. The phase composition, microstructure evolution, microhardness, frictional wear properties and corrosion resistance of 20Cr13 substrate and 15-5PH cladding layer were analyzed. The results indicated that the 15-5PH cladding layer was mainly composed of martensite, delta ferrite intergranular phase and spherical oxide inclusions. Compared with 20Cr13 substrate, 15-5PH cladding layer exhibited better microhardness, frictional wear properties and corrosion resistance. This work demonstrated the potential of 15-5PH alloy coatings for laser cladding of 20Cr13 stainless steel.},
  description = {A GWO-BPNN and genetic-algorithm approach for optimizing 15-5PH laser cladding on 20Cr13 steel, followed by microstructural and performance characterization.},
  keywords = {Characterization, Laser Cladding, Martensitic Stainless Steel, Parameter Optimization}
}

@article{du2023microstructure,
  title = {{20Cr13}表面激光熔覆{15-5PH}涂层组织和性能研究},
  author = {杜彦斌* and 何国华 and 周志杰 and 舒林森},
  year = {2023},
  month = may,
  journal = {激光与光电子学进展},
  volume = {60},
  number = {9},
  pages = {0914002},
  issn = {1006-4125},
  doi = {10.3788/LOP220854},
  urldate = {2026-06-29},
  langid = {chinese},
  abstract = {为改善20Cr13不锈钢零部件表面性能，利用激光熔覆技术在20Cr13不锈钢基材表面制备15-5PH合金涂层实现其表面强化。采用超景深显微镜、光学显微镜、X射线衍射仪、扫描电子显微镜、能谱仪以及摩擦磨损试验机等，对利用信噪比分析获得的较优工艺参数下的15-5PH合金涂层的几何形貌、微观组织、物相、显微硬度及摩擦磨损性能等进行分析。结果表明：熔道的熔宽、熔高、熔深与激光比能之间成正比；15-5PH涂层与20Cr13不锈钢冶金结合良好，无裂纹、气孔等缺陷；涂层组织以等轴晶和柱状晶等组成，涂层中析出了颗粒状NbC、NiC和ε-Cu等硬质相。显微硬度和摩擦磨损性能结果表明，涂层显微硬度约为基材的2.4倍，同时涂层耐磨性较基材有明显提升，其磨损形式为黏着磨损及磨粒磨损。},
  description = {研究20Cr13不锈钢表面15-5PH激光熔覆层的成形、组织、显微硬度与摩擦磨损性能。},
  keywords = {激光技术, 激光熔覆, 15-5PH, 表面强化, 信噪比, 组织性能}
}

@mastersthesis{he2023thesis,
  title = {基于激光熔覆的柱塞表面改性工艺优化研究},
  author = {何国华},
  year = {2023},
  month = may,
  school = {重庆工商大学},
  address = {重庆},
  type = {硕士学位论文},
  langid = {chinese},
  abstract = {柱塞泵作为液压系统最主要的机械部件之一，主要在高速、高压、重载且压力不断变化的环境下工作，常因其核心零部件柱塞磨损严重而造成停机。对柱塞零部件进行表面改性，可使其适应更为苛刻的工况并延长使用寿命。本文开展基于激光熔覆的柱塞表面改性工艺优化研究。首先，融入绿色低碳指标，构建柱塞表面改性方案综合评价指标体系，采用网络层次分析法、CRITIC法、最小相对信息熵及灰色关联改进的VIKOR法确定激光熔覆为最优方案。其次，以12Cr13柱塞为基材、Fe60自熔性粉末为熔覆粉末，开展试错法结合中心复合实验设计的多道搭接实验，利用GA-ACO优化的随机森林回归算法建立工艺参数与涂层稀释率、粉末利用率和表面平整度的预测模型，并采用GNSGA-II与TOPSIS进行多目标优化和工艺参数优选。最后，依据最优参数实施柱塞激光熔覆表面改性，通过物相、微观组织、显微硬度、耐腐蚀性和耐磨损性测试验证，结果表明改性后柱塞涂层的表面性能满足服役要求。},
  description = {面向柱塞表面改性，融合方案评价、随机森林预测、多目标优化与实验验证的激光熔覆工艺研究。},
  keywords = {激光熔覆, 表面改性, 柱塞, 工艺优化},
  note = {指导教师：杜彦斌}
}

@article{du2022inservice,
  title = {In-Service Machine Tool Remanufacturing: A Sustainable Resource-Saving and High-Valued Recovery Approach},
  author = {Yanbin Du* and Guohua He and Bo Li and Zhijie Zhou and Guoao Wu},
  year = {2022},
  month = jan,
  journal = {Environment, Development and Sustainability},
  casquartile = {中科院3区},
  jcrquartile = {JCR Q2},
  volume = {24},
  number = {1},
  pages = {1335--1358},
  issn = {1387-585X},
  doi = {10.1007/s10668-021-01499-6},
  urldate = {2026-06-29},
  langid = {english},
  abstract = {With great changes in production requirements, in-service machine tools may be unable to meet new production requirements. Aiming for this problem, a sustainable resource-saving and high-valued recovery approach for in-service machine tools is proposed, which integrates remanufacturing and product-service systems. In-service machine tool remanufacturing is defined as a new remanufacturing model based on condition monitoring and diagnosis, which is different from traditional used machine tool remanufacturing and new machine tool manufacturing mentioned in the current literature. A procedure framework of in-service machine tool remanufacturing is proposed, including condition monitoring and diagnosis, matching analysis, remanufacturability evaluation and decision-making, identification of potential problems, individualized redesign, disassembly, cleaning, inspection and classification, performance improvement as well as reassembly and inspection. Combining the remanufacturing practice of an in-service heavy-duty horizontal lathe, the comprehensive resource-efficient benefits of in-service machine tool remanufacturing are illustrated. The results show that the proposed remanufacturing model can restore in-service machine tools to like-new or better performance and upgrade their functionality, with great economic and social benefits. For implementation of this remanufacturing model, an in-depth analysis of supporting technologies such as condition monitoring and diagnosis and decision-making analysis should be done in future research to guarantee the production capacities of in-service machine tools.},
  description = {A framework integrating condition monitoring, diagnosis, redesign, and remanufacturing for sustainable recovery of in-service machine tools.},
  keywords = {Machine Tool, Remanufacturing, In-Service, Resource-Saving, Recovery}
}

@article{du2022multiparameter,
  title = {Multi-Parameter Optimization of Laser Cladding {15-5PH} Using {TOPSIS-GRA} Based on Combined Weighting Method},
  author = {Yanbin Du* and Zhijie Zhou and Guohua He and Lei Xu},
  year = {2022},
  month = mar,
  journal = {Journal of Materials Engineering and Performance},
  casquartile = {中科院4区},
  jcrquartile = {JCR Q3},
  volume = {31},
  number = {3},
  pages = {1934--1948},
  issn = {1059-9495},
  doi = {10.1007/s11665-021-06369-w},
  urldate = {2026-06-29},
  langid = {english},
  abstract = {As a martensitic precipitation-hardening stainless steel of high strength, high hardness, and excellent corrosion resistance, 15-5PH stainless steel can be used in laser cladding to repair components or improve surface performance. The cladding layer is affected by the process parameters directly. A Taguchi experiment of 15-5PH powder laser cladding is carried out on the surface of 45 steel to study the optimization of laser cladding process parameters. Analytic Hierarchy Process and Entropy Weighting Method are combined to determine the weight of each response index, while Technique for Order Preference by Similarity to Ideal Solution and Grey Relational Analysis are integrated to obtain better geometric performance of the cladding layer. Analysis of variance shows that scanning speed is the most significant parameter affecting the performance of the 15-5PH cladding layer. Validation experiments show that under the optimal process parameters, the three geometric performance responses of the cladding layer improve as expected. The optimized cladding layer has obvious advantages in geometric morphology and properties, which verifies the feasibility of the optimization method.},
  description = {A combined AHP-entropy weighting and TOPSIS-GRA method for multi-response optimization of 15-5PH laser-cladding parameters.},
  keywords = {Laser Cladding, Microstructure, Optimization, Properties, TOPSIS-GRA}
}

@article{du2022digitaltwin,
  title = {数字孪生驱动的机床预测性再制造新模式研究},
  author = {杜彦斌 and 李博 and 何国华 and 吴国奥},
  year = {2022},
  month = dec,
  journal = {计算机集成制造系统},
  volume = {28},
  number = {12},
  pages = {3758--3767},
  issn = {1006-5911},
  doi = {10.13196/j.cims.2022.12.005},
  urldate = {2026-06-29},
  langid = {chinese},
  abstract = {在分析机床再制造产业面临的挑战与现有事后型再制造模式不足的基础上，提出数字孪生驱动的机床预测性再制造新模式。将故障预测与健康管理融入再制造，提出并详细阐述了数字孪生驱动的机床预测性再制造新模式的关键技术体系与实现框架，包括机床数字孪生体构建、机床运行状态监测与诊断、机床故障预测与健康管理、机床再制造时机决策、机床再设计与再制造等。通过上述体系架构及关键技术实施，构建了一种多状态监测与诊断、数字孪生全过程驱动、再制造时机智能判断的在役机床事前预测性再制造运行机制，可有效减少突发性故障及停工损失并保障企业的制造能力。},
  description = {提出数字孪生全过程驱动、融合故障预测与健康管理的在役机床预测性再制造模式。},
  keywords = {再制造, 机床, 数字孪生, 预测性}
}
